class Solution {
public:
    void reverseString(vector<char>& s) {
         int l = 0;
        int r = s.size() - 1;
 
        while (l < r) {
            swap(s[l], s[r]);
            l++;
            r--;
        }
    
    }
};
stack<char> st;
for(int i = 0; i < s.size(); i++) {
    st.push(s[i]);
}
int i = 0;
while(!st.empty()) {
    s[i++] = st.top();
    st.pop();
}
    }
};

