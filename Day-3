// problem 1 -- 
// print 1-10 using a for loop 
#include <iostream>
using namespace std;

int main() {
   for ( int i = 1; i <= 10; i++) {
       cout << i << " ";
   }

    return 0;
}

// problem 2 -- 
// print 10-1 using a for loop 
#include <iostream>
using namespace std;

int main() {
   for ( int i = 10; i >= 1; i--) {
       cout << i << " ";
   }

    return 0;
}

// problem 3 -- 
// print 10-1 using a while loop 
#include <iostream>
using namespace std;

int main() {
  int i = 1;
  while (i <= 10) {
      cout << i << " ";
      i++;
  }
    return 0;
}
