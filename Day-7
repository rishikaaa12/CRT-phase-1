 //problem -3 --
// access modifiers 
// 1.3 - protected

 #include <iostream>
using namespace std;

class Parent{
    
protected:
int secretCode = 1234;
};

class Child : public Parent{
    public:
    void accessOfSecretCode() {
        cout << "secretCode of the locker is :" << secretCode;
    }
};

int main() {
Child obj1;
obj1.accessOfSecretCode();
}

