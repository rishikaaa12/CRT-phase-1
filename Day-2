// problem 2-- if-else condition 
// to verify users age whether eligible for vote 
#include <iostream>
using namespace std;

int main() {
int age;
cin >> age;
//if condition
if (age>=18) {
    //logic
    cout << "eligible for vote";
} else {
    //logic
    cout << "not eligible for vote";
}
return 0;
}


// problem 3-- nested if-else condition 
// to verify users age whether eligible for vote 
#include <iostream>
using namespace std;

int main() {
int age;
cin >> age;
if (age>=18) {
    if (age>=100) {
        cout << "eligible for vote but are super senior citizen";
    } else {
        cout << "eligible for vote";
    }
}else {
    if (age < 0) {
        cout << "enter a valid age number";
    } else {
        cout << "not eligible for vote";
    }
    
}
  

    return 0;
}


// problem 4-- ternary operator 
// find the greater no among 2
#include <iostream>
using namespace std;

int main() {
int a, b;
int max_Number;
cin >> a >> b;
//ternary operator
(a>b) ? a : b;
max_Number = (a > b) ? a : b;
cout << max_Number;
return 0;
}


// problem 5-- continue statement 
//print 1-n and avoid those no which are not divisible by 3
#include <iostream>
using namespace std;

int main() {
int n;
cin >> n;
for (int i = 1; i <= n; i++) {
    if (i % 3 == 0) {
        continue;
    }
    cout << i << "";
}
cout << "\n";
return 0;
}
