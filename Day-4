// problem 4 ---
// print a  mirrored right angled triangle 
#include <iostream>
using namespace std;
int main() {
     int n;
     cin >> n;
    // no of times or no of rows 
    for(int i = 1; i <= n; i++) {
        // no of spaces logic here 
        for(int j = n-i; j >= 1; j--) {
            cout <<" ";
        } for 
            (int k = 0; k <= i; k++) {
                cout << "*";
            }
        
        cout << "\n";
    }
    return 0;
}


// problem 5 ---
// print a  rectangle
#include <iostream>
using namespace std;
int main() {
     int row,col;
     cin >> row;
     cin >> col;
    
    for(int i = 1; i <= row; i++) {
        
        for(int j = 1; j <= col; j++) {
            cout <<"*";
        } 
        
        cout << "\n";
    }
    return 0;
}

// problem 6 ---
// print a hollow square 
#include <iostream>
using namespace std;
int main() {
 for(int i = 1; i <= 5; i++) {
        
        for(int j = 1; j <= 5; j++) {
            cout << " ";
            if(i == 1 || j ==1 || i==5 || j==5) {
                cout << "*";
            } else {
                cout << " ";
            }
        } 
        
        cout << "\n";
    }
    return 0;
}
