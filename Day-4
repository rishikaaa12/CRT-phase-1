// problem 1 ---
// print 1-10 , 10 no of times 
#include <iostream>
using namespace std;
int main() {
    // no of times to print the pattern 
    for(int i = 1; i <= 10; i++) {
        // this defines what to print in the pattern
        for(int j = 1; j<=10; j++) {
            cout << j << " ";
        }
        cout << "\n";
    }
    return 0;
}

// problem 2 ---
// print * , 10 no of times so that it forms a square
#include <iostream>
using namespace std;
int main() {
    // no of times to print the pattern 
    for(int i = 1; i <= 10; i++) {
        // this defines what to print in the pattern
        for(int j = 1; j<=10; j++) {
            cout <<"* ";
        }
        cout << "\n";
    }
    return 0;
}

