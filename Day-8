// 1.3 - hierarchial inheritance 

#include <iostream>
using namespace std;

class Vehicle{
    public:
    void start() {
        cout << "Vehicle starts " << "\n";
    }
};

class Car : public Vehicle {
    public:
    void drive() {
        cout << "Car is running " << "\n";
    }
};
class Bike : public Vehicle {
    public:
    void speed() {
        cout << "Bike is speedy " << "\n";
    }
};

int main() {
 Car obj1;

 obj1.drive();
 obj1.start();

Bike obj2;
 obj2.speed();
 obj2.start();
 
    return 0;
}
