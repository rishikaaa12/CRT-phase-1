// problem - 6 --
// polymorphism
// one name but many forms 
// same functions behave differently depending on the type of the object it called 
// types -- compile time , run time 
// 6.1 - compile time (function overloading/ static polymorphism)
// resolved at compile time
// function overloads -  same funct name but diff parameters
// faster execution as compared to run time 
// 6.2 - run time (function overriding/ dynamic polymorphism)
// same function name , same parameters but diff class 

// 6.1 - function overloading (compile time)

#include <iostream>
using namespace std;


void show(int var1, double var2) {
    cout << "Integer number: " << var1;
    cout << " and double number: " << var2 << endl;
}

void show(double var) {
    cout << "Double number: " << var << endl;
}

void show(int var) {
    cout << "Integer number: " << var << endl;
}
int main() {

    int a = 5;
    double b = 10.5;
    
  show(a);
show(b);

  show(a * b);

    return 0;
}

// problem - 6 --
// polymorphism
// one name but many forms 
// same functions behave differently depending on the type of the object it called 
// types -- compile time , run time 
// 6.1 - compile time (function overloading/ static polymorphism)
// resolved at compile time
// function overloads -  same funct name but diff parameters
// faster execution as compared to run time 
// 6.2 - run time (function overriding/ dynamic polymorphism)
// same function name , same parameters but diff class 

// 6.2 - function overriding (run time)

#include <iostream>
using namespace std;

class Animal {
    public:
   virtual void Sound() {
        cout << "Animal makes sound";
    }
   
};
class Dog : public Animal {
    public:
    void Sound() override {
        cout << "Dog makes a sound "<< "\n";
    }
  
};
class Cat : public Animal {
    public:
void Sound() override {
     cout << "Cat makes a sound " << "\n"; 
}
    
};

int main() {
Dog d;
Cat c;
d.Sound();
c.Sound();
    
}
