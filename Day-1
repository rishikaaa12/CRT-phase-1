// swap values of two variables
#include <iostream>
using namespace std;
int main(){
    int a;
    int b;
    
    cin >> a >> b;
    // swapping logic
    int temp = a;
    a = b;
    b = temp;
    
    
    cout << a << "\n" << b << endl;
    return 0;
}

//area of shapes
// 1-circle, 2-rect, 3- square
#include <iostream>
using namespace std;
int main(){
    int choice;
   cin >> choice;
   if(choice ==1) {
       double radius;
       cin >> radius;
       cout << 3.14 * radius * radius <<endl;
   } else if (choice == 2)
{
    double length, width;
    cin >> length >> width;
    
    cout << length * width << endl;
  } else if(choice ==3) {
      double base , height;
      cin >> base >> height;
      cout << 0.5 * base * height << endl;
  } else {
      cout << "invalid choice" << endl;
  }
  return 0;
}


